{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "k9s-dashboard",
  "version": "0.1.0",
  "identifier": "com.serial-experiments.k9s-dashboard",
  "build": {
    "frontendDist": "../../frontend/dist",
    "devUrl": "http://localhost:3141",
    "beforeDevCommand": "bun run --filter k9s-dashboard-frontend dev:desktop",
    "beforeBuildCommand": "bun run --filter k9s-dashboard-frontend build && node ../../scripts/build-sidecar.mjs"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "app", "dmg", "nsis", "msi"],
    "externalBin": ["binaries/k9s-backend"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
